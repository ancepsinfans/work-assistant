<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.work-assistant.meeting-brief</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/path/to/agent/meeting_brief.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/agent</string>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/tmp/meeting-brief-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/meeting-brief-stderr.log</string>
</dict>
</plist>
